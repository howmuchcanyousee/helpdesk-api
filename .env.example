APP_NAME=Helpdesk API
APP_ENV=development
APP_DEBUG=true
POSTGRES_DB=helpdesk
POSTGRES_USER=helpdesk
POSTGRES_PASSWORD=replace_with_a_local_development_password
DATABASE_URL=postgresql+psycopg://helpdesk:replace_with_a_local_development_password@db:5432/helpdesk
SECRET_KEY=replace_with_a_long_random_value
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Used only by the manual demo seed command in local development.
SEED_ADMIN_PASSWORD=local-admin-password
SEED_SUPPORT_PASSWORD=local-support-password
SEED_USER_PASSWORD=local-user-password
